{
  "title": "Credit Scoring MLOps",
  "uid": "credit-scoring",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{
        "expr": "rate(api_requests_total[1m]) * 60",
        "legendFormat": "{{endpoint}} {{status}}"
      }]
    },
    {
      "id": 2,
      "title": "Latency p50 / p95 (ms)",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(api_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(api_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 6},
      "targets": [{
        "expr": "rate(api_errors_total[5m])",
        "legendFormat": "errors/s"
      }],
      "options": {"colorMode": "background", "thresholds": {"steps": [
        {"value": 0, "color": "green"},
        {"value": 0.01, "color": "red"}
      ]}}
    },
    {
      "id": 4,
      "title": "Model Version",
      "type": "stat",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 6},
      "targets": [{"expr": "1", "legendFormat": "champion"}]
    },
    {
      "id": 5,
      "title": "Default Probability Distribution",
      "type": "histogram",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [{
        "expr": "rate(prediction_default_prob_bucket[10m])",
        "legendFormat": "{{le}}"
      }]
    },
    {
      "id": 6,
      "title": "Decision Distribution",
      "type": "piechart",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [{
        "expr": "prediction_decision_total",
        "legendFormat": "{{decision}}"
      }]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"}
}
