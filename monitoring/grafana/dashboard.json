{
  "title": "Credit Scoring MLOps",
  "uid": "credit-scoring",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(api_requests_total[1m]) * 60",
          "legendFormat": "{{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p50 / p95 (ms)",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(api_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(api_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(api_errors_total[5m])) or vector(0)",
          "legendFormat": "errors/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {
              "value": 0,
              "color": "green"
            },
            {
              "value": 0.01,
              "color": "red"
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Model Version",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "expr": "1",
          "legendFormat": "champion"
        }
      ]
    },
    {
      "id": 5,
      "title": "Default Probability Distribution (Heatmap)",
      "type": "heatmap",
      "description": "Heatmap of P(default) distribution over time. X = time \u00b7 Y = probability bucket \u00b7 Color = prediction density (yellow \u2192 red = more predictions). Use to detect drift: if the hot zone shifts from 0.2\u20130.4 to 0.7\u20130.9 over time, the model is drifting. calculate=false tells Grafana to use Prometheus pre-bucketed data directly (no double-bucketing).",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(increase(prediction_default_prob_bucket[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "time_series"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "YlOrRd",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255, 140, 0, 0.8)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "show": true
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": true,
          "yHistogram": false
        },
        "yAxis": {
          "axisPlacement": "left",
          "decimals": 1,
          "label": "P(default)",
          "reverse": false,
          "unit": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "dark-orange"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Decision Distribution",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "prediction_decision_total",
          "legendFormat": "{{decision}}"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}